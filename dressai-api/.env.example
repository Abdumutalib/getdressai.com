# =============================================================================
# DressAI API — веб (getdressai) ва илова (dressai-app) учун умумий бэкенд
# =============================================================================
# Локал стек: (1) getdressai npm run dev :8787  (2) бу сервер PORT=3000  (3) илова EXPO_PUBLIC_API_URL=<LAN>:3000
# Маркетплейс прокси учун: HYBRID_MARKETPLACE_UPSTREAM_URL=http://127.0.0.1:8787
# =============================================================================

OPENAI_API_KEY=your_openai_api_key
JWT_SECRET=change_this_in_production

# -----------------------------------------------------------------------------
# Stripe (тўлов тизими) — маҳаллий: sk_test_ / pk_test_; production: sk_live_ / pk_live_
# Dashboard: https://dashboard.stripe.com — Products → Price ID; Webhooks → signing secret
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Ойлик обуна (масалан $5/ой): POST /v1/stripe-trial; бўлмаса STRIPE_PRO_PRICE_ID fallback
STRIPE_MONTHLY_PRICE_ID=price_123456789
# Бир марта тўлов (Checkout /billing/create-checkout-session) — алоҳида price
STRIPE_PRO_PRICE_ID=price_xxx

# -----------------------------------------------------------------------------
# Paddle Billing (server SDK — @paddle/paddle-node-sdk) — API key from Dashboard → Developer tools
# Client-side checkout token lives in getdressai .env (PADDLE_CLIENT_SIDE_TOKEN), not here.
# -----------------------------------------------------------------------------
# PADDLE_API_KEY=pdl_live_apikey_...   # sandbox: pdl_sandbox_apikey_...
# PADDLE_ENVIRONMENT=sandbox
# npm run paddle:create-price -- pro_xxxxxxxx 1000 USD
#
# Paddle notifications: Dashboard → Developer tools → Notifications → signing secret
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_...   # webhook имзоси (API калитдан фарқли)
# POST https://api.getdressai.com/billing/paddle-webhook  (HTTPS; локал: ngrok / cloudflared)

# Supabase: subscriptions + user_quotas (service role — фақат серверда)
# Лойиҳа: https://supabase.com/dashboard/project/rmsluskirebmjxbnebyu
# SUPABASE_URL=https://rmsluskirebmjxbnebyu.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
AFFILIATE_TAG=
# Production (веб намечат https://getdressai.com): ALLOWED_ORIGIN=https://getdressai.com
ALLOWED_ORIGIN=*
PORT=3000

# --- Кўрсатиладиган billing сиёсати (/config → billing) — Stripe checkout дан мустақил рақамлар ---
# BILLING_YEARLY_PREFERRED=true
# BILLING_INCLUDED_GENERATIONS_PER_MONTH=20
# BILLING_OVERAGE_USD_PER_GEN=0.2
# BILLING_RECOMMENDED_DEPOSIT_USD=10
# Йиллик Stripe price (checkout keyinroқ): STRIPE_YEARLY_PRICE_ID=price_...

# production: NODE_ENV=production — JWT_SECRET мажбурий (dev placeholder тақиқланади)
# NODE_ENV=production

# dressai-api → getdressai маркетплейс прокси: getdressai .env да GETDRESSAI_MARKETPLACE_API_KEY билан бир хил қиймат
# MARKETPLACE_UPSTREAM_API_KEY=

# Amazon Associates — Product Advertising API (сервердагина; /analyze ёки каталог учун)
# 1) https://affiliate-program.amazon.com — Associates
# 2) Product Advertising API ёқиш
# 3) Access Key + Secret Key (IAM)
# 4) Partner tag (search havolalari билан бир хил бўлиши мумкин)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=yourtag-20

# Hybrid VTON: mobil ilova POST /v1/hybrid-vton → бу URL га прокси (GPU getdressai server)
# Misol: http://127.0.0.1:8787  yoki https://vton.yourdomain.com
HYBRID_VTON_SERVICE_URL=

# GetdressAI локал 8787 да Amazon search прокси (мобил ёки бошқа клиент)
# AMAZON_PA_API_UPSTREAM_URL=http://127.0.0.1:8787
AMAZON_PA_API_UPSTREAM_URL=

# eBay Browse search: mobil POST /v1/ebay-search → getdressai POST /api/ebay-search (keys in getdressai .env)
# EBAY_BROWSE_UPSTREAM_URL=http://127.0.0.1:8787
EBAY_BROWSE_UPSTREAM_URL=

# AliExpress Affiliate: mobil POST /v1/aliexpress-search → getdressai POST /api/aliexpress-search
# ALIEXPRESS_AFFILIATE_UPSTREAM_URL=http://127.0.0.1:8787
ALIEXPRESS_AFFILIATE_UPSTREAM_URL=

# Hybrid Amazon+eBay+AliExpress: mobil POST /v1/hybrid-marketplace-search → getdressai POST /api/hybrid-marketplace-search
# HYBRID_MARKETPLACE_UPSTREAM_URL=http://127.0.0.1:8787
HYBRID_MARKETPLACE_UPSTREAM_URL=

# eBay Developer (https://developer.ebay.com — Create Application, OAuth)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_RUNAME=

# --- Rate limiting (optional overrides) ---
# Global limiter skips health/config by default.
# GLOBAL_RATE_LIMIT_SKIP_PATHS=/health,/config
# GLOBAL_RATE_LIMIT_WINDOW_MS=60000
# GLOBAL_RATE_LIMIT_MAX=6000
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=40
# MARKETPLACE_RATE_LIMIT_WINDOW_MS=60000
# MARKETPLACE_RATE_LIMIT_MAX=60
# HEAVY_RATE_LIMIT_WINDOW_MS=60000
# HEAVY_RATE_LIMIT_MAX=20

# Optional Redis backend for distributed rate limiting
# RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379
