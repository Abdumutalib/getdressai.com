# =============================================================================
# DressAI API (Node / Express)
# Copy to: getdressai.com/dressai-api/.env
# =============================================================================

# Core
PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change_this_in_production
DATA_ENCRYPTION_KEY=
DATABASE_URL=

# OpenAI / AI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_WHISPER_MODEL=
ENABLE_VOICE_TRANSCRIPTION=false
MAX_AUDIO_SIZE=20971520
SMOKE_EMAIL=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paddle / billing
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=
PADDLE_PRODUCT_ID=

# Optional billing policy
BILLING_YEARLY_PREFERRED=true
BILLING_INCLUDED_GENERATIONS_PER_MONTH=20
BILLING_OVERAGE_USD_PER_GEN=0.2
BILLING_RECOMMENDED_DEPOSIT_USD=10

# Stripe (if still used by this backend)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_7_99=

# Affiliate / marketplace
AFFILIATE_TAG=
MARKETPLACE_UPSTREAM_API_KEY=
HYBRID_MARKETPLACE_UPSTREAM_URL=
HYBRID_VTON_SERVICE_URL=
AMAZON_PA_API_UPSTREAM_URL=
EBAY_BROWSE_UPSTREAM_URL=
ALIEXPRESS_AFFILIATE_UPSTREAM_URL=

# Amazon PA API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# eBay
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_RUNAME=
EBAY_USE_SANDBOX=false
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_OAUTH_SCOPE=
EBAY_PRICE_CURRENCY=USD

# Optional Redis-backed rate limiting
RATE_LIMIT_REDIS_URL=
REDIS_URL=

# Rate limit overrides
GLOBAL_RATE_LIMIT_SKIP_PATHS=/health,/config
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=6000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=40
MARKETPLACE_RATE_LIMIT_WINDOW_MS=60000
MARKETPLACE_RATE_LIMIT_MAX=60
HEAVY_RATE_LIMIT_WINDOW_MS=60000
HEAVY_RATE_LIMIT_MAX=20
