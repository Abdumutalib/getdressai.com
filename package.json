{
  "name": "dressai-backend",
  "version": "1.0.0",
  "description": "DressAI backend with outfit analysis and image generation",
  "main": "server.js",
  "scripts": {
    "build": "npm install --prefix dressai-web && npm run web:build",
    "start": "node server.js",
    "start:3001": "set PORT=3001&& node server.js",
    "port:3000": "node scripts/port-status.js 3000",
    "web:dev": "npm --prefix dressai-web run dev",
    "web:build": "npm --prefix dressai-web run build",
    "supabase:migrate-users": "node scripts/migrate-users-to-supabase.js",
    "supabase:seed-shop": "node scripts/seed-shop-catalog-to-supabase.js"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.104.0",
    "stripe": "^21.0.1"
  }
}
